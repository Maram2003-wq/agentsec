{
  "name": "Security Pipeline - Consolidation",
  "nodes": [
    {
      "name": "Schedule (Weekly)",
      "type": "n8n-nodes-base.scheduleTrigger",
      "parameters": {
        "rule": {
          "interval": [{"field": "week", "interval": 1}]
        }
      }
    },
    {
      "name": "Run OpenVAS Scan",
      "type": "n8n-nodes-base.executeCommand",
      "parameters": {
        "command": "python3 /home/maram/agentsec/openvas_integration.py"
      }
    },
    {
      "name": "Get Latest Scans",
      "type": "n8n-nodes-base.executeQuery",
      "parameters": {
        "query": "SELECT * FROM scans ORDER BY scan_date DESC LIMIT 5"
      }
    },
    {
      "name": "Consolidate Results",
      "type": "n8n-nodes-base.code",
      "parameters": {
        "jsCode": "// Fusionner les résultats\nconst fastScans = $input.all();\nconst openvasResults = $('Run OpenVAS Scan').first().json;\n\nconst consolidated = {\n  scan_id: new Date().toISOString(),\n  fast_scans: fastScans,\n  openvas: openvasResults,\n  total_findings: fastScans.length + (openvasResults.vulnerabilities?.length || 0)\n};\n\nreturn [{ json: consolidated }];"
      }
    },
    {
      "name": "AI Prioritization",
      "type": "n8n-nodes-base.httpRequest",
      "parameters": {
        "url": "https://api.groq.com/openai/v1/chat/completions",
        "method": "POST",
        "body": "={{ $json }}"
      }
    },
    {
      "name": "Send Report",
      "type": "n8n-nodes-base.emailSend",
      "parameters": {
        "to": "security@example.com",
        "subject": "Weekly Security Report",
        "html": "={{ $json.ai_analysis }}"
      }
    }
  ]
}
